---
import Layout from './Layout.astro';
import { SITE, SVEDEN_LINKS } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  updatedAt?: string;
}

const {
  title,
  description,
  updatedAt = new Date().toISOString().slice(0, 10),
} = Astro.props;

const fullTitle = `${title} — ${SITE.name}`;
const path = Astro.url.pathname.replace(/\/$/, '');
---

<Layout title={fullTitle} description={description ?? title}>
  <header class="sveden-topbar">
    <div class="sveden-topbar__inner">
      <a href="/" class="sveden-topbar__brand">
        <img src="/images/logo.png" alt="" width="32" height="32" loading="lazy" />
        <span>{SITE.name}</span>
      </a>
      <nav class="sveden-topbar__nav" aria-label="Основная навигация">
        <a href="/">Главная</a>
        <a href="/sveden/common" class:list={[{ active: path === '/sveden' || path === '/sveden/common' }]}>Сведения об организации</a>
        <a href="/#pricing">Цены</a>
        <a href="/#faq">Вопросы</a>
      </nav>
    </div>
  </header>

  <div class="sveden-shell">
    <aside class="sveden-sidebar" aria-label="Разделы сведений">
      <h2 class="sveden-sidebar__title">Сведения об образовательной организации</h2>
      <nav>
        <ul>
          {SVEDEN_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[{ active: path === link.href }]}
                aria-current={path === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <p class="sveden-sidebar__law">
        Раздел размещён в соответствии со&nbsp;ст. 29 ФЗ&nbsp;№&nbsp;273-ФЗ
        «Об&nbsp;образовании в&nbsp;Российской Федерации» и&nbsp;Приказом Рособрнадзора
        №&nbsp;1493 от&nbsp;14.08.2020.
      </p>
    </aside>

    <main class="sveden-main">
      <div class="sveden-breadcrumbs">
        <a href="/">Главная</a>
        <span aria-hidden="true">›</span>
        <a href="/sveden/common">Сведения об организации</a>
        {path !== '/sveden/common' && (
          <>
            <span aria-hidden="true">›</span>
            <span>{title}</span>
          </>
        )}
      </div>

      <article class="sveden-article">
        <h1>{title}</h1>
        <slot />
      </article>

      <footer class="sveden-updated">
        <p>Дата обновления: <time datetime={updatedAt}>{updatedAt}</time></p>
      </footer>
    </main>
  </div>
</Layout>

<style>
  .sveden-topbar {
    background: var(--color-brand-navy, #0e2f1a);
    color: white;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .sveden-topbar__inner {
    max-width: 1240px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1.25rem;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .sveden-topbar__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: white;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .sveden-topbar__brand img {
    border-radius: 50%;
    background: white;
  }
  .sveden-topbar__nav {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }
  .sveden-topbar__nav a {
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
  }
  .sveden-topbar__nav a:hover {
    color: white;
  }
  .sveden-topbar__nav a.active {
    color: white;
    font-weight: 600;
  }

  .sveden-shell {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    padding: 2rem 1.25rem 4rem;
  }

  .sveden-sidebar {
    position: sticky;
    top: 1.5rem;
    align-self: start;
    background: #f5f5f2;
    border: 1px solid #e5e5df;
    border-radius: 14px;
    padding: 1.25rem 1rem;
    font-size: 0.9rem;
  }
  .sveden-sidebar__title {
    font-family: var(--font-display, 'Unbounded', system-ui, sans-serif);
    font-size: 0.92rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #444;
    margin: 0 0 0.9rem;
    line-height: 1.4;
  }
  .sveden-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.1rem;
  }
  .sveden-sidebar a {
    display: block;
    padding: 0.5rem 0.65rem;
    border-radius: 8px;
    color: #333;
    text-decoration: none;
    line-height: 1.4;
    font-size: 0.88rem;
    transition: background 0.15s, color 0.15s;
  }
  .sveden-sidebar a:hover {
    background: #eceae3;
  }
  .sveden-sidebar a.active {
    background: var(--color-brand-green, #1f5132);
    color: white;
    font-weight: 600;
  }
  .sveden-sidebar__law {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e5df;
    font-size: 0.75rem;
    line-height: 1.45;
    color: #666;
  }

  .sveden-main {
    min-width: 0;
  }
  .sveden-breadcrumbs {
    display: flex;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #666;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .sveden-breadcrumbs a {
    color: #666;
    text-decoration: none;
  }
  .sveden-breadcrumbs a:hover {
    color: var(--color-brand-green, #1f5132);
    text-decoration: underline;
  }

  .sveden-article {
    background: white;
    border: 1px solid #e5e5df;
    border-radius: 16px;
    padding: 2rem 2.25rem;
  }
  .sveden-article h1 {
    font-family: var(--font-display, 'Unbounded', system-ui, sans-serif);
    font-size: clamp(1.5rem, 2.2vw, 2.1rem);
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }
  .sveden-article :global(h2) {
    font-family: var(--font-display, 'Unbounded', system-ui, sans-serif);
    font-size: 1.2rem;
    margin: 2rem 0 0.75rem;
  }
  .sveden-article :global(h3) {
    font-size: 1rem;
    margin: 1.5rem 0 0.5rem;
    font-weight: 700;
  }
  .sveden-article :global(p),
  .sveden-article :global(li) {
    font-size: 0.96rem;
    line-height: 1.65;
    color: #222;
  }
  .sveden-article :global(p) {
    margin: 0 0 0.85rem;
  }
  .sveden-article :global(ul),
  .sveden-article :global(ol) {
    padding-left: 1.25rem;
    margin: 0 0 1rem;
  }
  .sveden-article :global(ul li),
  .sveden-article :global(ol li) {
    margin: 0 0 0.35rem;
  }
  .sveden-article :global(a) {
    color: var(--color-brand-green, #1f5132);
    text-decoration: underline;
  }
  .sveden-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 0.9rem;
  }
  .sveden-article :global(th),
  .sveden-article :global(td) {
    border: 1px solid #e5e5df;
    padding: 0.6rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }
  .sveden-article :global(th) {
    background: #f5f5f2;
    font-weight: 700;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #444;
  }
  .sveden-article :global(dl) {
    display: grid;
    grid-template-columns: minmax(200px, 240px) 1fr;
    gap: 0.6rem 1.5rem;
    margin: 0 0 1rem;
    font-size: 0.94rem;
  }
  .sveden-article :global(dt) {
    color: #666;
    font-weight: 500;
  }
  .sveden-article :global(dd) {
    margin: 0;
    color: #222;
  }
  .sveden-article :global(.doc-missing) {
    color: #a33;
    font-style: italic;
  }
  .sveden-article :global(.doc-note) {
    background: #fff8e6;
    border-left: 3px solid #e5a400;
    padding: 0.85rem 1rem;
    border-radius: 6px;
    margin: 1rem 0;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .sveden-updated {
    margin-top: 1.25rem;
    font-size: 0.82rem;
    color: #666;
    text-align: right;
  }

  @media (max-width: 900px) {
    .sveden-shell {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 1.25rem 1rem 3rem;
    }
    .sveden-sidebar {
      position: static;
    }
    .sveden-article {
      padding: 1.5rem 1.25rem;
    }
    .sveden-article :global(dl) {
      grid-template-columns: 1fr;
      gap: 0.15rem 0;
    }
    .sveden-article :global(dd) {
      margin-bottom: 0.5rem;
    }
  }
</style>
