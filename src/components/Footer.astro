---
import { SITE, NAV_LINKS } from '../lib/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <div class="footer__logo">
        <span class="brand-mark">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="2"/>
            <path d="M14 6L18 18H10L14 6Z" fill="currentColor"/>
          </svg>
        </span>
        <div>
          <div class="footer__brand-name">{SITE.name}</div>
          <div class="footer__brand-sub">{SITE.legalName} · с 2002 года</div>
        </div>
      </div>
      <p class="footer__about">
        Автошкола в&nbsp;Перми: 3&nbsp;филиала, 8&nbsp;учебных автомобилей, обучение по&nbsp;категориям А, B, С&nbsp;с&nbsp;2002&nbsp;года. Работаем по&nbsp;действующей лицензии Министерства образования Пермского края.
      </p>
    </div>

    <div class="footer__col">
      <h4>Навигация</h4>
      <ul>
        {NAV_LINKS.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
        <li><a href="/privacy">Политика конфиденциальности</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Филиалы</h4>
      <ul>
        {SITE.branches.map((b) => (
          <li>
            <div class="footer__branch">{b.title}</div>
            <div class="footer__district">{b.district}</div>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer__col">
      <h4>Связь</h4>
      <ul class="footer__contacts">
        {SITE.phones.map((p) => (
          <li><a href={`tel:${p.tel}`}>{p.label}</a></li>
        ))}
        <li>
          <a href={SITE.whatsapp} target="_blank" rel="noopener">WhatsApp</a>
        </li>
        <li>
          <a href={SITE.socials.vk} target="_blank" rel="noopener">ВКонтакте</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p>© {year} {SITE.legalName}. Все права защищены.</p>
      <p class="footer__license">
        Лицензия: {SITE.license.issuedBy}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-brand-navy);
    color: white;
    padding: 4rem 1.25rem 0;
  }
  .footer__inner {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer__logo {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .footer .brand-mark {
    background: white;
    color: var(--color-brand-navy);
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .footer__brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
  }
  .footer__brand-sub {
    font-size: 0.82rem;
    opacity: 0.6;
    margin-top: 2px;
  }
  .footer__about {
    font-size: 0.92rem;
    opacity: 0.7;
    line-height: 1.6;
    max-width: 42ch;
  }

  .footer__col h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
    font-family: var(--font-sans);
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .footer__col a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .footer__col a:hover {
    color: var(--color-brand-orange);
  }
  .footer__branch {
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .footer__district {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
    margin-top: 2px;
  }
  .footer__contacts li {
    font-weight: 600;
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.5rem 0;
  }
  .footer__bottom-inner {
    max-width: 1240px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.82rem;
  }

  @media (max-width: 980px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-bottom: 2rem;
    }
  }
</style>
