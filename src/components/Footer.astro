---
import { SITE, NAV_LINKS } from '../lib/site';
const year = new Date().getFullYear();
const { legal, license } = SITE;
const issuedAt = new Date(license.issuedAt).toLocaleDateString('ru-RU');
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <div class="footer__logo">
        <div class="footer__logo-wrap" aria-hidden="true">
          <img src="/images/logo.png" alt="" width="56" height="56" loading="lazy" />
        </div>
        <div>
          <div class="footer__brand-name">{SITE.name}</div>
          <div class="footer__brand-sub">{SITE.legalName} · с 2002 года</div>
        </div>
      </div>
      <p class="footer__about">
        Автошкола в&nbsp;Перми: 4&nbsp;учебных класса, 10&nbsp;учебных автомобилей, 2&nbsp;мотоцикла,
        своя площадка в&nbsp;Ясырях. Обучение по&nbsp;категориям A и&nbsp;B с&nbsp;2002&nbsp;года.
      </p>
    </div>

    <div class="footer__col">
      <h4>Навигация</h4>
      <ul>
        {NAV_LINKS.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
        <li><a href="/sveden/common">Сведения об организации</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Документы</h4>
      <ul>
        <li><a href="/sveden/document">Все документы</a></li>
        <li><a href="/sveden/paid_edu">Платные услуги</a></li>
        <li><a href="/privacy">Политика персональных данных</a></li>
        <li><a href="/terms">Пользовательское соглашение</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Связь</h4>
      <ul class="footer__contacts">
        {SITE.phones.map((p) => (
          <li><a href={`tel:${p.tel}`}>{p.label}</a></li>
        ))}
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li><a href={SITE.socials.vk} target="_blank" rel="noopener">ВКонтакте</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__legal">
    <div class="footer__legal-inner">
      <p class="footer__legal-name">{legal.fullName}</p>
      <dl class="footer__legal-grid">
        <div>
          <dt>Юридический адрес</dt>
          <dd>{legal.legalAddress}</dd>
        </div>
        <div>
          <dt>ИНН</dt>
          <dd>{legal.inn}</dd>
        </div>
        <div>
          <dt>КПП</dt>
          <dd>{legal.kpp}</dd>
        </div>
        <div>
          <dt>ОГРН</dt>
          <dd>{legal.ogrn}</dd>
        </div>
        <div>
          <dt>Лицензия</dt>
          <dd>
            №&nbsp;{license.number} от&nbsp;{issuedAt} ({license.series} №&nbsp;{license.blankNumber})
          </dd>
        </div>
        <div>
          <dt>Кем выдана</dt>
          <dd>{license.issuedBy}</dd>
        </div>
      </dl>
      <p class="footer__legal-claims">
        Претензии по&nbsp;качеству образовательных услуг принимаются в&nbsp;приёмной автошколы письменно
        или на&nbsp;e-mail <a href={`mailto:${SITE.email}`}>{SITE.email}</a>. Срок рассмотрения — 10&nbsp;рабочих дней.
      </p>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p>© {year} {SITE.legalName}. Все права защищены.</p>
      <p class="footer__license-link"><a href="/sveden/common">Сведения об образовательной организации</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-brand-navy);
    color: white;
    padding: 4rem 1.25rem 0;
  }
  .footer__inner {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer__logo {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .footer__logo-wrap {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: white;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .footer__logo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .footer__brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
  }
  .footer__brand-sub {
    font-size: 0.82rem;
    opacity: 0.6;
    margin-top: 2px;
  }
  .footer__about {
    font-size: 0.92rem;
    opacity: 0.7;
    line-height: 1.6;
    max-width: 42ch;
  }

  .footer__col h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
    font-family: var(--font-sans);
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .footer__col a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .footer__col a:hover {
    color: var(--color-brand-orange);
  }
  .footer__contacts li {
    font-weight: 600;
  }

  .footer__legal {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.75rem 0;
  }
  .footer__legal-inner {
    max-width: 1240px;
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .footer__legal-name {
    font-weight: 600;
    color: white;
    margin-bottom: 0.85rem;
  }
  .footer__legal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.65rem 2rem;
    margin: 0 0 1rem;
  }
  .footer__legal-grid div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .footer__legal-grid dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 500;
  }
  .footer__legal-grid dd {
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
  }
  .footer__legal-claims {
    margin: 0;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
  }
  .footer__legal-claims a {
    color: rgba(255, 255, 255, 0.85);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.5rem 0;
  }
  .footer__bottom-inner {
    max-width: 1240px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.82rem;
  }
  .footer__bottom-inner a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
  }
  .footer__bottom-inner a:hover {
    color: white;
  }

  @media (max-width: 980px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-bottom: 2rem;
    }
  }
</style>
