---
import { NAV_LINKS, SITE } from '../lib/site';
---

<header class="site-header" id="siteHeader">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand" aria-label={SITE.name}>
      <img src="/images/logo.png" alt="" class="brand-mark" width="48" height="48" decoding="async" fetchpriority="high" />
      <span class="brand-name">
        <span class="brand-name__top">АС-Луч</span>
        <span class="brand-name__sub">автошкола с 2002</span>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Основная навигация">
      {NAV_LINKS.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a href={`tel:${SITE.phones[0].tel}`} class="site-header__phone" aria-label="Позвонить">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        <span>{SITE.phones[0].label}</span>
      </a>
      <a href="#contact" class="btn-primary site-header__cta">Записаться</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 250, 247, 0.85);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s, background 0.25s;
  }
  .site-header.scrolled {
    border-bottom-color: var(--color-brand-border);
    background: rgba(250, 250, 247, 0.96);
  }
  .site-header__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-brand-ink);
    font-family: var(--font-display);
    text-decoration: none;
  }
  .brand-mark {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }
  .brand-name {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-name__top {
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
  }
  .brand-name__sub {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.75rem;
    color: var(--color-brand-muted);
    margin-top: 2px;
  }
  .site-header__nav {
    display: flex;
    gap: 1.75rem;
    margin-left: auto;
  }
  .site-header__nav a {
    color: var(--color-brand-ink);
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    position: relative;
    transition: color 0.2s;
  }
  .site-header__nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 2px;
    background: var(--color-brand-orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }
  .site-header__nav a:hover {
    color: var(--color-brand-navy);
  }
  .site-header__nav a:hover::after {
    transform: scaleX(1);
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .site-header__phone {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-brand-ink);
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    transition: background 0.2s, color 0.2s;
  }
  .site-header__phone:hover {
    color: var(--color-brand-navy);
    background: var(--color-brand-navy-50);
  }
  .site-header__cta {
    padding: 0.6rem 1.25rem !important;
    font-size: 0.95rem !important;
  }

  @media (max-width: 1100px) {
    .site-header__nav { display: none; }
  }
  @media (max-width: 640px) {
    .site-header__phone span { display: none; }
    .site-header__phone { padding: 0.45rem; }
    .site-header__cta { display: none; }
    .brand-name__sub { display: none; }
    .site-header__inner { gap: 0.75rem; }
  }
</style>

<script>
  const header = document.getElementById('siteHeader');
  window.addEventListener(
    'scroll',
    () => {
      header?.classList.toggle('scrolled', window.scrollY > 12);
    },
    { passive: true }
  );
</script>
