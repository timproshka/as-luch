---
const items = [
  {
    icon: 'book',
    title: 'Теория по утверждённой программе',
    text: 'Обучаем по программам Министерства просвещения (Приказ №505). 134 часа: ПДД, безопасность, устройство авто, медподготовка, работа на компьютере.',
  },
  {
    icon: 'steering',
    title: 'Современный автопарк',
    text: '8 учебных автомобилей с дублирующими педалями. МКПП и АКПП. Техобслуживание каждые 3 месяца.',
  },
  {
    icon: 'target',
    title: 'Автодром + город',
    text: 'Отрабатываем парковку, эстакаду, развороты. Затем выезжаем в городской поток на реальных маршрутах ГИБДД Перми.',
  },
  {
    icon: 'shield',
    title: 'Лицензия и договор',
    text: 'Все обучение — по официальному договору с фиксированной ценой. Лицензия Министерства образования Пермского края — действующая.',
  },
  {
    icon: 'document',
    title: 'Документы в ГИБДД',
    text: 'Помогаем оформить все бумаги: заявление, экзаменационный лист, копии, свидетельство об окончании курсов, квитанцию за водительское удостоверение.',
  },
  {
    icon: 'refresh',
    title: 'Пересдача — без драмы',
    text: 'Если часть экзамена не сдал — пересдаёшь только её, не весь экзамен. Внутреннюю пересдачу в автошколе делаем бесплатно.',
  },
];

const iconMap: Record<string, string> = {
  book: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20V2H6.5A2.5 2.5 0 0 0 4 4.5v15z',
  steering: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM12 7v5M12 12l-4 3M12 12l4 3',
  target: 'M12 2a10 10 0 1 1 0 20 10 10 0 0 1 0-20zM12 6a6 6 0 1 0 0 12 6 6 0 0 0 0-12zM12 10a2 2 0 1 1 0 4 2 2 0 0 1 0-4z',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zM9 12l2 2 4-4',
  document: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM14 2v6h6M9 13h6M9 17h6',
  refresh: 'M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10M3.51 15a9 9 0 0 0 14.85 3.36L23 14',
};
---

<section class="standards" id="standards">
  <div class="standards__inner">
    <div class="standards__head reveal">
      <span class="eyebrow">Что входит в&nbsp;обучение</span>
      <h2>Единые стандарты&nbsp;— во&nbsp;всех&nbsp;3&nbsp;филиалах</h2>
      <p>
        Мы&nbsp;работаем 23&nbsp;года и&nbsp;знаем: ученику не&nbsp;важно, кто конкретно его преподаватель&nbsp;— ему важно, чтобы&nbsp;он&nbsp;научился водить и&nbsp;сдал с&nbsp;первого раза. Поэтому у&nbsp;нас единые программы, единые машины и&nbsp;единый результат.
      </p>
    </div>

    <div class="standards__grid" data-stagger>
      {items.map((it) => (
        <article class="standard">
          <div class="standard__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={iconMap[it.icon]} />
            </svg>
          </div>
          <h3>{it.title}</h3>
          <p>{it.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .standards {
    padding: 5rem 1.25rem;
  }
  .standards__inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .standards__head {
    max-width: 760px;
    margin-bottom: 3rem;
  }
  .standards__head p {
    font-size: 1.125rem;
    color: var(--color-brand-muted);
    margin-top: 1rem;
  }
  .standards__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .standard {
    background: white;
    border-radius: 18px;
    padding: 1.75rem;
    border: 1px solid var(--color-brand-border);
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.2s;
  }
  .standard:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
    border-color: var(--color-brand-navy-50);
  }
  .standard__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--color-brand-navy-50);
    color: var(--color-brand-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .standard h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .standard p {
    color: var(--color-brand-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }
  @media (max-width: 900px) {
    .standards__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .standards__grid { grid-template-columns: 1fr; }
  }
</style>
