---
import { SITE } from '../lib/site';

const iconPaths = {
  motorcycle: 'M5 17a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm14 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM9 7h3l3 6h-5M9 7l2 6M14 6h3v2',
  car: 'M5 17h14M5 17l1.5-5h11L19 17M5 17v2h2v-2M17 17v2h2v-2M7 12l1-3h8l1 3',
  truck: 'M3 17V7h11v10H3zM14 11h4l3 3v3h-7v-6zM7 17a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm11 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
};
---

<section class="categories" id="categories">
  <div class="categories__inner">
    <div class="categories__head reveal">
      <span class="eyebrow">Выберите категорию</span>
      <h2>Три категории — каждая под&nbsp;свой путь</h2>
      <p>
        От&nbsp;мотоцикла&nbsp;«А» до&nbsp;грузовика&nbsp;«С». Обучение по&nbsp;утверждённым программам Министерства просвещения (Приказ №505).
      </p>
    </div>

    <div class="categories__grid" data-stagger>
      {SITE.categories.map((cat) => (
        <article class={`cat-card tilt ${cat.popular ? 'cat-card--popular' : ''}`}>
          {cat.popular && <span class="cat-card__badge">Популярная</span>}
          <div class="cat-card__icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[cat.icon as keyof typeof iconPaths]} />
            </svg>
          </div>
          <div class="cat-card__code">{cat.code}</div>
          <h3>{cat.title}</h3>
          <p class="cat-card__sub">{cat.subtitle}</p>
          <p class="cat-card__desc">{cat.description}</p>
          <a href="#contact" class="cat-card__cta">
            Выбрать
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .categories {
    padding: 4rem 1.25rem;
  }
  .categories__inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .categories__head {
    max-width: 720px;
    margin-bottom: 3rem;
  }
  .categories__head p {
    font-size: 1.125rem;
    color: var(--color-brand-muted);
    max-width: 58ch;
    margin-top: 1rem;
  }
  .categories__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .cat-card {
    position: relative;
    background: white;
    border-radius: 22px;
    padding: 2rem 1.75rem 1.75rem;
    border: 1px solid var(--color-brand-border);
    display: flex;
    flex-direction: column;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.35s, border-color 0.2s;
  }
  .cat-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card);
    border-color: transparent;
  }
  .cat-card--popular {
    background: linear-gradient(145deg, #fff 0%, #fff 60%, var(--color-brand-orange-50) 100%);
    border-color: var(--color-brand-orange);
  }
  .cat-card__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.3rem 0.7rem;
    background: var(--color-brand-orange);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 999px;
  }
  .cat-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--color-brand-navy-50);
    color: var(--color-brand-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .cat-card--popular .cat-card__icon {
    background: var(--color-brand-orange);
    color: white;
  }
  .cat-card__code {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 4rem;
    line-height: 0.9;
    color: var(--color-brand-navy);
    letter-spacing: -0.05em;
    margin-bottom: 0.25rem;
  }
  .cat-card--popular .cat-card__code {
    color: var(--color-brand-orange);
  }
  .cat-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.2rem;
  }
  .cat-card__sub {
    font-size: 0.85rem;
    color: var(--color-brand-muted);
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .cat-card__desc {
    color: var(--color-brand-muted);
    font-size: 0.95rem;
    line-height: 1.55;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .cat-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-brand-navy);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
    transition: gap 0.2s, color 0.2s;
    align-self: flex-start;
  }
  .cat-card__cta:hover {
    gap: 0.7rem;
    color: var(--color-brand-orange);
  }
  @media (max-width: 900px) {
    .categories__grid { grid-template-columns: 1fr; }
    .cat-card__code { font-size: 3rem; }
  }
</style>
